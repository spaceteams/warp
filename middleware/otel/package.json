{
  "name": "@spaceteams/warp-otel",
  "version": "0.3.0",
  "description": "Open Telemetry middleware for Warp",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@spaceteams/warp": "workspace:*",
    "@opentelemetry/api": "1.9.0"
  },
  "devDependencies": {
    "@opentelemetry/sdk-metrics": "2.6.0",
    "@opentelemetry/sdk-trace-node": "2.6.0",
    "@opentelemetry/sdk-trace-base": "2.6.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/spaceteams/warp.git",
    "directory": "middleware/pino"
  },
  "keywords": [
    "warp",
    "middleware",
    "otel",
    "tracing",
    "metrics",
    "open-telemetry"
  ],
  "license": "MIT"
}
