{
  "name": "@spaceteams/warp-pino",
  "version": "1.0.0",
  "description": "Pino logger middleware for Warp",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@spaceteams/warp": "workspace:^",
    "pino": ">=9.0.0"
  },
  "devDependencies": {
    "@spaceteams/warp": "workspace:^",
    "pino": "10.3.1"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepublishOnly": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/spaceteams/warp.git",
    "directory": "middleware/pino"
  },
  "keywords": [
    "warp",
    "middleware",
    "pino",
    "logger",
    "logging"
  ],
  "license": "MIT"
}
